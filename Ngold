  const today22=t.k22, today24=t.k24;
  const validHist=hist.filter(h=>h.v22);
  const mom=(validHist[validHist.length-1].v22-validHist[0].v22)/validHist[0].v22;
  const days=validHist.length-1;
  const dailyMom=mom/days;

  const scenarios=[
    {cls:'bull', label:'⚖️ Stabilisation / Mild Recovery', color:'var(--g200)', conf:'60%',
     note:`National 22K bounced from ₹12,980 (Jun 27-28) to ₹13,110 (Jun 29). Chennai still elevated at ₹13,300. Floor likely near ₹12,900-13,000 with wedding season support.`,
     mult:0.4},
    {cls:'bear', label:'🐻 Continued Softness', color:'var(--dn)', conf:'55%',
     note:`From June 20 high ₹13,435 to Jun 29 ₹13,110, a real -2.4% slide. June peak was ₹14,630 — already -10.4% off that. Hawkish Fed (86% probability Dec 2026 hike per IBJA's Kothari) keeps pressure on.`,
     mult:-0.7}
  ];

  const tfs=[{l:'+1 Day',d:1},{l:'+2 Days',d:2},{l:'+3 Days',d:3},{l:'+5 Days',d:5},{l:'+7 Days',d:7}];

  document.getElementById('pg').innerHTML=scenarios.map(sc=>`
    <div class="pred-card ${sc.cls}">
      <div class="pglow"></div>
      <div class="pred-top">
        <div><div class="pred-eye">7-Day Forecast · National 22K</div>
        <div class="pred-label" style="color:${sc.color}">${sc.label}</div></div>
        <div class="conf">Conf. ${sc.conf}</div>
      </div>
      <div class="pred-note">${sc.note}</div>
      <div class="pred-rows">${tfs.map(tf=>{
        const p22final=Math.round(today22+(today22*dailyMom*sc.mult*tf.d));
        const p24final=Math.round(p22final*24/22);
        const diff=p22final-today22, dc=diff>=0?'up':'dn', ds=diff>=0?'▲':'▼';
        return`<div class="pred-row">
          <div class="pred-when">${tf.l}</div>
          <div style="display:flex;align-items:center;gap:10px">
            <div><div class="pv1">${f(p22final)} <em>22K/g</em></div>
            <div class="pv8">24K: ${f(p24final)} · 8g: ${f(p22final*8)}</div></div>
            <div class="dir-chip ${dc}">${ds} ${f(Math.abs(diff))}</div>
          </div></div>`;
      }).join('')}</div>
    </div>`).join('');
}

function renderHistTable(){
  const rows=[...DB.history].reverse();
  document.getElementById('hb').innerHTML=rows.map((r,i)=>{
    const prev=rows[i+1],ch=prev&&prev.v22?r.v22-prev.v22:null,chp=ch&&prev.v22?(ch/prev.v22*100).toFixed(2):null;
    const col=ch===null?'var(--tx3)':ch>0?'var(--up)':ch<0?'var(--dn)':'var(--tx3)';
    const sy=ch===null?'':ch>0?'▲':ch<0?'▼':'●';
    const today=i===0;
    return`<tr style="${today?'background:rgba(245,197,24,.05)':''}">
      <td style="color:${today?'var(--g200)':'var(--tx1)'};font-weight:${today?700:400}">${r.d}, 2026${today?' ← Latest':''}</td>
      <td style="color:var(--g200);font-weight:${today?700:400}">${f(r.v22)}</td>
      <td>${f(r.v24)}</td>
      <td>${f(r.v22*8)}</td>
      <td style="color:${col}">${ch!==null?sy+' '+f(Math.abs(ch)):'baseline'}</td>
      <td class="src-cell">${r.jeweller} · ${r.src}</td>
    </tr>`;
  }).join('');
}

function renderCityTable(){
  document.getElementById('cb').innerHTML=Object.entries(DB.cities).map(([city,r])=>{
    const isCh=city==='Chennai';
    return`<tr style="${isCh?'background:rgba(245,197,24,.05)':''}">
      <td style="color:${isCh?'var(--g200)':'var(--tx0)'};font-weight:${isCh?700:500}">${city}${isCh?' ⭐':''}</td>
      <td style="color:${isCh?'var(--g200)':'var(--tx1)'};font-weight:${isCh?700:400}">${f(r.k22)}</td>
      <td>${f(r.k22*8)}</td><td>${f(r.k24)}</td><td>${f(r.k24*8)}</td>
      <td style="color:var(--tx2)">${f(r.k18)}</td>
    </tr>`;
  }).join('');
}

function renderInvestTable(){
  document.getElementById('investBody').innerHTML=DB.investments.map(inv=>`
    <tr><td style="color:var(--g200);font-weight:500">${inv.name}</td><td>${inv.benefit}</td>
    <td>${inv.liquidity}</td><td style="color:var(--tx2)">${inv.best}</td></tr>`).join('');
}

function renderFestivals(){
  document.getElementById('festGrid').innerHTML=DB.festivals.map(fe=>`
    <div class="fest-card"><div class="fest-icon">${fe.icon}</div>
    <div class="fest-name">${fe.name}</div><div class="fest-date">${fe.date}</div>
    <div class="fest-tag">${fe.tag}</div>
    <div style="font-size:9px;color:var(--tx3);margin-top:6px;font-family:'Hind',sans-serif">${fe.note}</div></div>`).join('');
}

function animRefresh(){
  document.querySelectorAll('.rc-rate').forEach(el=>{el.classList.remove('flip');void el.offsetWidth;el.classList.add('flip');});
  document.getElementById('sTime').textContent='Checked: '+new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
  document.getElementById('sMsg').textContent=`✓ Data current through Jun 29, 2026 · 22K: ${f(DB.today.k22)} · Share today's rate to extend`;
  document.getElementById('sMsg').className='ok';
}

function initReveal(){
  const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');obs.unobserve(e.target);}});},{threshold:.06});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
}

function init(){
  buildTicker();
  buildPred();
  renderCards();
  renderUSBanner();
  renderInds();
  renderWeekChart();
  render24KChart();
  renderHistTable();
  renderCityTable();
  renderInvestTable();
  renderFestivals();
  initReveal();
  document.getElementById('sTime').textContent='Loaded: '+new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}
init();
</script>
</body>
</html>
